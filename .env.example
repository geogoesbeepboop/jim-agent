# --- Network / facilitator ---------------------------------------------------
# Base Sepolia testnet (CAIP-2). Switch to eip155:8453 for Base mainnet (Phase 5).
NETWORK=eip155:84532
# Free testnet facilitator. Coinbase CDP facilitator is the production option.
FACILITATOR_URL=https://x402.org/facilitator

# --- Seller side --------------------------------------------------------------
# The address that RECEIVES payments for our paywalled endpoints.
EVM_ADDRESS=
SELLER_HOST=0.0.0.0
SELLER_PORT=4021
PING_PRICE=$0.01

# --- Buyer side ---------------------------------------------------------------
# The private key we PAY with (self-testing our seller now; upstream data later).
# Generate with: uv run jim-wallet new
EVM_PRIVATE_KEY=

# --- Phase 1: research engine -------------------------------------------------
# SEC requires a descriptive User-Agent with real contact info on every request.
SEC_USER_AGENT=jim-agent georgeandrade93@gmail.com
# Price of one /research/fundamentals call.
RESEARCH_PRICE=$0.25
# The synthesizer + judge need this. The deterministic sourcing gate does NOT.
ANTHROPIC_API_KEY=
RESEARCH_MODEL=claude-sonnet-4-6
JUDGE_MODEL=claude-haiku-4-5-20251001
ENABLE_JUDGE=true
JUDGE_THRESHOLD=0.8
# Stronger judge model for high-stakes runs (jim-research --high-stakes). The judge
# now returns a per-claim checklist either way; this just raises the reviewer.
JUDGE_HIGH_STAKES_MODEL=claude-sonnet-4-6

# --- Research quality: memo cache + completeness ------------------------------
# Serve a recent identical memo (same {product}:{identifier}:{mode}, unchanged data
# fingerprint, still passes the gate) instead of re-synthesizing → $0 inference on
# repeated identical queries. Moved data re-synthesizes automatically.
MEMO_CACHE_ENABLED=true
MEMO_CACHE_TTL_SECONDS=86400             # also bound freshness even if data looks same
# Completeness is a signal, not a gate: share of *material* line items the memo must
# cite to "pass" (below this just lowers the quality score; it never rejects a run).
COMPLETENESS_MATERIAL_FLOOR=0.6

# --- Phase 1 (optional): Langfuse tracing -------------------------------------
# Leave blank to disable tracing entirely (the pipeline runs identically).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Phase 2: buy side + margin engine ----------------------------------------
# Postgres+pgvector (docker compose up -d). Unset → in-memory store (no persistence).
DATABASE_URL=postgresql+asyncpg://jim:jim@localhost:5432/jim

# The Graph (paid upstream data source over x402):
#   false → buy from the local /mock-graph vendor on Base Sepolia (free testnet USDC)
#   true  → buy from gateway.thegraph.com on Base MAINNET (REAL USDC, ~$0.01/query)
GRAPH_LIVE=false
# Going live also needs a Base-MAINNET-funded key (defaults to EVM_PRIVATE_KEY):
GRAPH_EVM_PRIVATE_KEY=

# Pricing + economics.
TOKEN_RESEARCH_PRICE=$0.50
MOCK_GRAPH_PRICE=$0.01
# Hard per-query data ceiling. Doubles as the x402 PRICE CAP: the buy path reads
# the seller's dynamic 402 price and REFUSES above this (the real Graph price is
# unpublished). Audit before mainnet: `uv run python scripts/graph_probe.py WETH`.
PER_QUERY_BUDGET_USD=0.10
PURCHASE_CACHE_TTL_SECONDS=86400
# Multi-chain token research uses :chain on the identifier (WETH:base, ARB:arbitrum)
# across Uniswap-v3 on Ethereum/Base/Arbitrum/Polygon — same x402 rail. See ADR-0007.

# --- Data sources: free public-domain macro (Fed funds / CPI / Treasury) -------
# A free, redistributable macro product citing US-gov primary sources (NOT FRED —
# its ToS forbids redistribution). $0 data cost → pure margin. Optional free BLS
# key lifts the CPI request limit (keyless v1 is the fallback).
MACRO_RESEARCH_PRICE=$0.15
BLS_API_KEY=

# --- Phase 3: expanded metrics + adversarial debate ---------------------------
# Enrich equities with market + technical metrics (Yahoo: Market Cap, P/E, P/B,
# 52W range, SMA50/200, RSI, MACD, volume). Best-effort; degrades to EDGAR-only.
ENABLE_PRICES=true
# Bull/bear/judge adversarial review before the memo is written.
ENABLE_DEBATE=true
DEBATE_MODEL=claude-sonnet-4-6

# --- Phase 4: continuous monitors (the "motley crew") -------------------------
# A monitor re-runs research on a schedule, diffs against its last baseline, and
# only pays to write — and only pushes — when a deterministic trigger fires.
# Use Postgres (DATABASE_URL above) for a standing fleet; the in-memory store
# does not persist monitors across separate CLI invocations.
MONITOR_DEFAULT_INTERVAL_SECONDS=86400   # poll cadence for a new monitor (1d)
MONITOR_POLL_SECONDS=60                   # scheduler tick: how often to check for due monitors
MONITOR_MAX_CONCURRENCY=4                 # due monitors run with this much parallelism
MONITOR_COOLDOWN_SECONDS=21600           # suppress a repeat of the SAME signal for 6h
MONITOR_UPDATE_PRICE=$0.10               # price_out booked per delivered update
MONITOR_DEFAULT_MODE=agent               # updates default to terse/metric-dense prose
# Run the scheduler inside the seller process (else use `jim-monitor serve`).
MONITOR_AUTOSTART=false
# HMAC secret for signing webhook deliveries (subscribers verify authenticity).
# Defaults to EVM_PRIVATE_KEY if unset; set a dedicated secret in production.
MONITOR_WEBHOOK_SECRET=
MONITOR_WEBHOOK_TIMEOUT_SECONDS=10
# Default materiality thresholds (deterministic; per-monitor overrides allowed).
MONITOR_PRICE_MOVE_PCT=5.0               # |price move| ≥ this % is notable
MONITOR_METRIC_CHANGE_PCT=10.0           # |any metric move| ≥ this % is notable
MONITOR_RSI_OVERBOUGHT=70.0
MONITOR_RSI_OVERSOLD=30.0

# --- Phase 5: marketplace, discovery, mainnet ---------------------------------
# Public service identity, advertised in /catalog + the Bazaar discovery manifest
# so other agents can find us. Keep names short / ≤ 5 tags (indexers cap these).
SERVICE_NAME=jim
SERVICE_ICON_URL=
# Absolute base URL for the discovery manifest + Bazaar resource URLs.
# Unset → derived from the request host (or seller host/port).
PUBLIC_BASE_URL=
# Pricing tiers (deterministic discounts off the base per-call price).
AGENT_TIER_DISCOUNT_PCT=10.0
BUNDLE_TIER_DISCOUNT_PCT=20.0
BUNDLE_MAX_ITEMS=10
# Human UI has two payment paths (no extra config needed for either):
#   1. "Pay with wallet" — a browser hitting a paid route gets x402's bundled
#      wallet paywall (MetaMask / Coinbase Wallet → real EIP-3009 settlement);
#      agents still get the machine-readable 402. Always on. See ADR-0005.
#   2. The free "Preview" action, which can optionally self-settle: when true,
#      POST /ui/checkout settles a REAL x402 payment by having jim buy its own
#      endpoint (needs a funded EVM_PRIVATE_KEY). false → labelled free preview.
UI_SETTLE_VIA_X402=false
# Settlement audit log (GET /admin, jim-admin): every paid call is recorded with
# the buyer address + settlement tx in `payment_receipts`. Run `uv run jim-initdb`
# once after upgrading to create the table. No config required.
# MCP server (jim-mcp): jim as an x402-gated MCP server. Needs `uv sync --extra mcp`.
MCP_HOST=0.0.0.0
MCP_PORT=4022
# Mainnet cutover. Switch NETWORK to eip155:8453 + point FACILITATOR_URL at a
# mainnet facilitator (the testnet one cannot settle on mainnet). Run the preflight:
#   uv run jim-market mainnet      (reads state; never moves money)
# Optional read-only RPC so the preflight can report ETH (gas) + USDC balances:
MAINNET_RPC_URL=
# Facilitator economics to check our prices against (operator-supplied):
FACILITATOR_MIN_USDC=0.0                 # smallest settleable amount, if any
FACILITATOR_FEE_BPS=0.0                  # facilitator fee in basis points, if any
